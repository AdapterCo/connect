PORT=3009
NODE_ENV=production

# JWT — use pelo menos 32 caracteres aleatorios (ex: openssl rand -base64 48)
JWT_SECRET=replace-with-at-least-32-random-characters

# Banco de dados
DATABASE_URL=postgresql://appuser:STRONG_PASSWORD@db:5432/adapterconnect?schema=public

# Chave de criptografia simetrica para segredos no banco (32+ chars)
ENCRYPTION_KEY=replace-with-at-least-32-random-characters

# Mercado Pago da PLATAFORMA (conta do dono do SaaS, nao do cliente)
# Obter em: https://www.mercadopago.com.br/developers/panel/credentials
PLATFORM_MP_ACCESS_TOKEN=APP_USR-seu-access-token-aqui
PLATFORM_MP_PUBLIC_KEY=APP_USR-sua-public-key-aqui

# Secret HMAC para validar webhooks do Mercado Pago (opcional — nao utilizado neste projeto)
# O sistema usa polling para verificar pagamentos, nao webhooks.
MP_WEBHOOK_SECRET=

# Dominio publico da aplicacao (sem https://)
DOMAIN=connect.adapterco.com.br

# Politica de retencao de dados (LGPD)
RETENTION_ENABLED=false
AUDIT_LOG_RETENTION_DAYS=365
SYSTEM_LOG_RETENTION_DAYS=180
MESSAGE_RETENTION_DAYS=0
