datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Plan {
  id            String    @id @default(uuid())
  name          String    @unique
  max_instances Int       @default(1)
  max_users     Int       @default(2)
  price         Float     @default(0)
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  companies     Company[]
  subscriptions Subscription[]
}

model Company {
  id              String             @id @default(uuid())
  name            String
  slug            String             @unique
  logo_url        String?
  primary_color   String?
  plan            String             @default("free")
  plan_id         String?
  max_instances   Int                @default(1)
  max_users       Int                @default(2)
  is_active       Boolean            @default(true)
  expires_at      DateTime?
  mp_access_token String?
  mp_public_key   String?
  mp_enabled      Boolean            @default(false)
  mp_webhook_url  String?
  created_at      DateTime           @default(now())
  updated_at      DateTime           @updatedAt
  plan_relation   Plan?              @relation(fields: [plan_id], references: [id], onDelete: SetNull)
  users           User[]
  settings        Settings?
  instances       Instance[]
  chats           Chat[]
  scheduled       ScheduledMessage[]
  logs            Log[]
  metrics         Metric[]
  subscriptions   Subscription[]
  invoices        Invoice[]
  auditLogs       AuditLog[]
  categories      Category[]
  products        Product[]
  orders          Order[]
  printers        Printer[]
}

model User {
  id              String               @id @default(uuid())
  name            String
  username        String               @unique
  password        String
  role            String
  status          String               @default("offline")
  company_id      String
  created_at      DateTime             @default(now())
  updated_at      DateTime             @updatedAt
  company         Company              @relation(fields: [company_id], references: [id], onDelete: Cascade)
  resetTokens     PasswordResetToken[]
}

model Settings {
  id            String   @id @default(uuid())
  company_id    String   @unique
  ai_enabled    Boolean  @default(false)
  ai_provider   String   @default("mock")
  gemini_key    String?
  openai_key    String?
  grok_key      String?
  gemini_model  String?
  openai_model  String?
  grok_model    String?
  system_prompt String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  company       Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model Instance {
  id         String   @id
  name       String
  phone      String?
  status     String   @default("disconnected")
  company_id String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  company    Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  chats      Chat[]
}

model Chat {
  id            String    @id
  client_name   String
  client_phone  String
  status        String    @default("iniciada")
  assigned_to   String?
  ai_active     Boolean   @default(true)
  tags          String[]
  is_favorite   Boolean   @default(false)
  is_archived   Boolean   @default(false)
  is_blocked    Boolean   @default(false)
  sector        String?
  company_id    String
  instance_id   String
  waiting_since DateTime?
  claimed_at    DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  company       Company   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  instance      Instance  @relation(fields: [instance_id], references: [id], onDelete: Cascade)
  messages      Message[]
  orders        Order[]
}

model Message {
  id             String   @id @default(uuid())
  chat_id        String
  sender         String
  sender_id      String?
  text           String
  timestamp      DateTime @default(now())
  is_ai          Boolean  @default(false)
  is_note        Boolean  @default(false)
  is_scheduled   Boolean  @default(false)
  media_url      String?
  media_type     String?
  file_name      String?
  payment_id     String?
  payment_url    String?
  payment_status String?
  chat           Chat     @relation(fields: [chat_id], references: [id], onDelete: Cascade)
}

model ScheduledMessage {
  id            String   @id @default(uuid())
  chat_id       String
  client_name   String
  text          String?
  scheduledTime DateTime
  media_url     String?
  media_type    String?
  file_name     String?
  created_by    String
  company_id    String
  created_at    DateTime @default(now())
  company       Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model Log {
  id         String   @id @default(uuid())
  message    String
  company_id String
  timestamp  DateTime @default(now())
  company    Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model Metric {
  id               String   @id @default(uuid())
  type             String
  chat_id          String
  attendant_id     String?
  is_ai            Boolean  @default(false)
  duration_seconds Int
  company_id       String
  timestamp        DateTime @default(now())
  company          Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model Subscription {
  id                    String    @id @default(uuid())
  company_id            String
  plan_id               String
  status                String    @default("active")
  current_period_start  DateTime
  current_period_end    DateTime
  mp_subscription_id    String?
  mp_payer_id           String?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  company               Company   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  plan                  Plan      @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  invoices              Invoice[]
}

model Invoice {
  id              String        @id @default(uuid())
  company_id      String
  subscription_id String?
  amount          Float
  status          String        @default("pending")
  mp_payment_id   String?
  mp_payment_url  String?
  due_date        DateTime
  paid_at         DateTime?
  created_at      DateTime      @default(now())
  company         Company       @relation(fields: [company_id], references: [id], onDelete: Cascade)
  subscription    Subscription? @relation(fields: [subscription_id], references: [id], onDelete: SetNull)
}

model PasswordResetToken {
  id         String   @id @default(uuid())
  user_id    String
  token      String   @unique
  expires_at DateTime
  used       Boolean  @default(false)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(uuid())
  company_id String
  user_id    String?
  user_name  String?
  action     String
  entity     String
  entity_id  String?
  details    String?
  ip         String?
  user_agent String?
  timestamp  DateTime @default(now())
  company    Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model Category {
  id         String    @id @default(uuid())
  name       String
  slug       String
  is_active  Boolean   @default(true)
  sort_order Int       @default(0)
  company_id String
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  company    Company   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  products   Product[]
  
  printer_id String?
  printer    Printer?  @relation(fields: [printer_id], references: [id], onDelete: SetNull)

  @@unique([company_id, slug])
}

model Product {
  id           String            @id @default(uuid())
  name         String
  slug         String
  description  String?
  price        Float
  image_url    String?
  is_active    Boolean           @default(true)
  sort_order   Int               @default(0)
  category_id  String
  company_id   String
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt
  category     Category          @relation(fields: [category_id], references: [id], onDelete: Cascade)
  company      Company           @relation(fields: [company_id], references: [id], onDelete: Cascade)
  variants     ProductVariant[]
  addons       ProductAddon[]
  orderItems   OrderItem[]

  @@unique([company_id, slug])
}

model ProductVariant {
  id         String   @id @default(uuid())
  name       String
  price_diff Float    @default(0)
  product_id String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
}

model ProductAddon {
  id         String   @id @default(uuid())
  name       String
  price      Float
  product_id String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  orderItems OrderItemAddon[]
}

model Order {
  id              String      @id @default(uuid())
  chat_id         String
  status          String      @default("pending")
  subtotal        Float
  discount        Float       @default(0)
  total           Float
  payment_method  String?
  payment_status  String      @default("pending")
  notes           String?
  printed         Boolean     @default(false)
  printed_at      DateTime?
  company_id      String
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt
  chat            Chat        @relation(fields: [chat_id], references: [id], onDelete: Cascade)
  company         Company     @relation(fields: [company_id], references: [id], onDelete: Cascade)
  items           OrderItem[]
}

model OrderItem {
  id         String           @id @default(uuid())
  product_id String
  variant_id String?
  quantity   Int              @default(1)
  unit_price Float
  total      Float
  notes      String?
  order_id   String
  created_at DateTime         @default(now())
  product    Product          @relation(fields: [product_id], references: [id], onDelete: Cascade)
  order      Order            @relation(fields: [order_id], references: [id], onDelete: Cascade)
  addons     OrderItemAddon[]
}

model OrderItemAddon {
  id         String       @id @default(uuid())
  addon_id   String
  quantity   Int          @default(1)
  order_item_id String
  created_at DateTime     @default(now())
  addon      ProductAddon @relation(fields: [addon_id], references: [id], onDelete: Cascade)
  orderItem  OrderItem    @relation(fields: [order_item_id], references: [id], onDelete: Cascade)
}

model Printer {
  id         String     @id @default(uuid())
  name       String
  ip_address String
  port       Int        @default(9100)
  is_active  Boolean    @default(true)
  company_id String
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt
  company    Company    @relation(fields: [company_id], references: [id], onDelete: Cascade)
  categories Category[]
}
