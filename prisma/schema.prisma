datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Plan {
  id            String    @id @default(uuid())
  name          String    @unique
  max_instances Int       @default(1)
  max_users     Int       @default(2)
  price         Float     @default(0)
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  companies     Company[]
  subscriptions Subscription[]
}

model Company {
  id              String             @id @default(uuid())
  name            String
  slug            String             @unique
  logo_url        String?
  primary_color   String?
  plan            String             @default("free")
  plan_id         String?
  max_instances   Int                @default(1)
  max_users       Int                @default(2)
  is_active       Boolean            @default(true)
  expires_at      DateTime?
  mp_access_token String?
  mp_public_key   String?
  mp_enabled      Boolean            @default(false)
  mp_webhook_url  String?
  created_at      DateTime           @default(now())
  updated_at      DateTime           @updatedAt
  plan_relation   Plan?              @relation(fields: [plan_id], references: [id], onDelete: SetNull)
  users           User[]
  settings        Settings?
  instances       Instance[]
  chats           Chat[]
  scheduled       ScheduledMessage[]
  logs            Log[]
  metrics         Metric[]
  subscriptions   Subscription[]
  invoices        Invoice[]
  auditLogs       AuditLog[]
}

model User {
  id              String               @id @default(uuid())
  name            String
  username        String               @unique
  password        String
  role            String
  status          String               @default("offline")
  company_id      String
  created_at      DateTime             @default(now())
  updated_at      DateTime             @updatedAt
  company         Company              @relation(fields: [company_id], references: [id], onDelete: Cascade)
  resetTokens     PasswordResetToken[]
}

model Settings {
  id            String   @id @default(uuid())
  company_id    String   @unique
  ai_enabled    Boolean  @default(false)
  ai_provider   String   @default("mock")
  gemini_key    String?
  openai_key    String?
  grok_key      String?
  gemini_model  String?
  openai_model  String?
  grok_model    String?
  system_prompt String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  company       Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model Instance {
  id         String   @id
  name       String
  phone      String?
  status     String   @default("disconnected")
  company_id String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  company    Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  chats      Chat[]
}

model Chat {
  id            String    @id
  client_name   String
  client_phone  String
  status        String    @default("iniciada")
  assigned_to   String?
  ai_active     Boolean   @default(true)
  tags          String[]
  is_favorite   Boolean   @default(false)
  is_archived   Boolean   @default(false)
  is_blocked    Boolean   @default(false)
  sector        String?
  company_id    String
  instance_id   String
  waiting_since DateTime?
  claimed_at    DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  company       Company   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  instance      Instance  @relation(fields: [instance_id], references: [id], onDelete: Cascade)
  messages      Message[]
}

model Message {
  id             String   @id @default(uuid())
  chat_id        String
  sender         String
  sender_id      String?
  text           String
  timestamp      DateTime @default(now())
  is_ai          Boolean  @default(false)
  is_note        Boolean  @default(false)
  is_scheduled   Boolean  @default(false)
  media_url      String?
  media_type     String?
  file_name      String?
  payment_id     String?
  payment_url    String?
  payment_status String?
  chat           Chat     @relation(fields: [chat_id], references: [id], onDelete: Cascade)
}

model ScheduledMessage {
  id            String   @id @default(uuid())
  chat_id       String
  client_name   String
  text          String?
  scheduledTime DateTime
  media_url     String?
  media_type    String?
  file_name     String?
  created_by    String
  company_id    String
  created_at    DateTime @default(now())
  company       Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model Log {
  id         String   @id @default(uuid())
  message    String
  company_id String
  timestamp  DateTime @default(now())
  company    Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model Metric {
  id               String   @id @default(uuid())
  type             String
  chat_id          String
  attendant_id     String?
  is_ai            Boolean  @default(false)
  duration_seconds Int
  company_id       String
  timestamp        DateTime @default(now())
  company          Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model Subscription {
  id                    String    @id @default(uuid())
  company_id            String
  plan_id               String
  status                String    @default("active")
  current_period_start  DateTime
  current_period_end    DateTime
  mp_subscription_id    String?
  mp_payer_id           String?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  company               Company   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  plan                  Plan      @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  invoices              Invoice[]
}

model Invoice {
  id              String        @id @default(uuid())
  company_id      String
  subscription_id String?
  amount          Float
  status          String        @default("pending")
  mp_payment_id   String?
  mp_payment_url  String?
  due_date        DateTime
  paid_at         DateTime?
  created_at      DateTime      @default(now())
  company         Company       @relation(fields: [company_id], references: [id], onDelete: Cascade)
  subscription    Subscription? @relation(fields: [subscription_id], references: [id], onDelete: SetNull)
}

model PasswordResetToken {
  id         String   @id @default(uuid())
  user_id    String
  token      String   @unique
  expires_at DateTime
  used       Boolean  @default(false)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(uuid())
  company_id String
  user_id    String?
  user_name  String?
  action     String
  entity     String
  entity_id  String?
  details    String?
  ip         String?
  user_agent String?
  timestamp  DateTime @default(now())
  company    Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
}
